rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /profile_images/{fileName} {
      // Public read: avatars are shown across the app.
      allow read: if true;

      // Only the owner may write their own <uid>.jpg, capped at 5MB and images only.
      allow write: if request.auth != null
                   && fileName == request.auth.uid + '.jpg'
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');

      // Only the owner may delete their own <uid>.jpg.
      allow delete: if request.auth != null
                    && fileName == request.auth.uid + '.jpg';
    }
  }
}
