# Calendly Configuration
# Copy this file to .env and fill in your actual values

# Calendly webhook signing secret — from your Calendly webhook subscription
CALENDLY_WEBHOOK_SECRET=

# Calendly OAuth app credentials — register at https://developer.calendly.com/apps
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=
# Must match the redirect URI registered in your Calendly OAuth app
CALENDLY_REDIRECT_URI=https://us-central1-halal-social-prod.cloudfunctions.net/calendlyOAuthCallback

# Firebase project configuration (automatically set by Firebase)
FIREBASE_PROJECT_ID=halal-social-prod